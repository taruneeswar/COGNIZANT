index.css

/* Universal Selector */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

/* Google Font */

@import url('https://fonts.googleapis.com/css2?family=Poppins&display=swap');

body{
    font-family:'Poppins',sans-serif;
    padding:20px;
}

/* Header */

#mainHeader{
    background:linear-gradient(to right,#007bff,#00c6ff);
    color:white;
    padding:20px;
    text-align:center;
    margin:20px 0;
}

/* Navigation */

nav ul{
    list-style:none;
    display:flex;
    gap:20px;
    margin-bottom:20px;
}

nav a{
    text-decoration:none;
    color:#007bff;
}

nav a:hover{
    color:red;
}

/* Event Card */

.eventCard{
    background:rgba(0,123,255,0.1);
    border:2px solid #007bff;
    padding:20px;
    margin:15px 0;
}

h2{
    color:#007bff;
}

h3,p{
    margin-top:10px;
}

/* Table */

table{
    width:100%;
    border-collapse:collapse;
    margin-top:20px;
}

th,td{
    border:1px solid black;
    padding:10px;
    text-align:center;
}

tr:nth-child(even){
    background:#f2f2f2;
}

/* Multi Column */

.news{
    margin-top:30px;
    column-count:2;
    column-gap:30px;
    column-rule:1px solid gray;
}

/* Responsive */

@media screen and (max-width:768px){

    nav ul{
        flex-direction:column;
    }

    body{
        font-size:14px;
    }

    .eventCard{
        width:100%;
    }
}
