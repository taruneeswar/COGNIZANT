<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Local Community Event Portal</title>

```
<style>
    body{
        font-family: Arial, sans-serif;
        margin:20px;
        background:#f4f4f4;
    }

    #welcomeBanner{
        background:blue;
        color:white;
        padding:15px;
        border-radius:5px;
    }

    .highlight{
        background:yellow;
        font-weight:bold;
    }

    .event-image{
        width:180px;
        height:120px;
        border:2px solid black;
    }

    form{
        background:white;
        padding:15px;
        border-radius:5px;
    }

    section{
        margin-top:25px;
    }
</style>

<script>
    function validatePhone(){
        let phone=document.getElementById("phone").value;
        if(phone.length!=10){
            alert("Enter valid 10 digit phone number");
        }
    }

    function showFee(){
        let event=document.getElementById("eventType").value;
        let fee=document.getElementById("fee");

        if(event==="Workshop")
            fee.innerHTML="Fee: ₹500";
        else if(event==="Seminar")
            fee.innerHTML="Fee: ₹300";
        else
            fee.innerHTML="Fee: ₹200";
    }

    function submitForm(){
        document.getElementById("confirmation").value =
        "Registration Submitted Successfully!";
    }

    function enlargeImage(img){
        img.style.width="300px";
        img.style.height="200px";
    }

    function countChars(){
        let count=document.getElementById("feedback").value.length;
        document.getElementById("charCount").innerHTML=
        "Characters: "+count;
    }

    function videoReady(){
        document.getElementById("videoMsg").innerHTML=
        "Video ready to play";
    }

    function savePreference(){
        localStorage.setItem(
            "eventType",
            document.getElementById("eventType").value
        );
    }

    function loadPreference(){
        let pref=localStorage.getItem("eventType");
        if(pref){
            document.getElementById("eventType").value=pref;
        }
    }

    function clearPreferences(){
        localStorage.clear();
        sessionStorage.clear();
        alert("Preferences Cleared");
    }

    function findLocation(){
        navigator.geolocation.getCurrentPosition(
            function(position){
                document.getElementById("location").innerHTML=
                "Latitude: "+position.coords.latitude+
                "<br>Longitude: "+position.coords.longitude;
            },
            function(error){
                alert("Location access denied");
            },
            {
                enableHighAccuracy:true,
                timeout:5000
            }
        );
    }

    window.onbeforeunload=function(){
        return "Are you sure you want to leave?";
    };

    window.onload=loadPreference;
</script>
```

</head>

<body>

<!-- Navigation -->

<nav>
    <a href="#home">Home</a> |
    <a href="#events">Events</a> |
    <a href="#contact">Contact</a> |
    <a href="help.html" target="_blank">Help</a>
</nav>

<!-- Welcome Banner -->

<div id="welcomeBanner">
    Welcome to Local Community Event Portal
    <span style="color:red;font-weight:bold;">
        Special Offer
    </span>
</div>

<section id="home">
    <h2 class="highlight">Home</h2>
    <p>Community events portal for residents.</p>
</section>

<section id="events">
    <h2>Event Gallery</h2>

```
<table border="1">
    <tr>
        <td>
            <img src="https://via.placeholder.com/180"
            class="event-image"
            alt="Event1"
            title="Event1"
            ondblclick="enlargeImage(this)">
        </td>

        <td>
            <img src="https://via.placeholder.com/180"
            class="event-image"
            alt="Event2"
            title="Event2">
        </td>

        <td>
            <img src="https://via.placeholder.com/180"
            class="event-image"
            alt="Event3"
            title="Event3">
        </td>
    </tr>

    <tr>
        <td>Music Fest</td>
        <td>Tech Meetup</td>
        <td>Food Carnival</td>
    </tr>
</table>
```

</section>

<section>
    <h2>Event Registration Form</h2>

```
<form>
    <input type="text"
           placeholder="Enter Name"
           autofocus required><br><br>

    <input type="email"
           placeholder="Enter Email"
           required><br><br>

    <input type="date" required><br><br>

    <input type="text"
           id="phone"
           placeholder="Phone Number"
           onblur="validatePhone()"><br><br>

    <select id="eventType"
            onchange="showFee();savePreference()">
        <option>Workshop</option>
        <option>Seminar</option>
        <option>Cultural Event</option>
    </select>

    <p id="fee"></p>

    <textarea id="feedback"
              onkeyup="countChars()"
              placeholder="Feedback"></textarea>

    <p id="charCount">Characters: 0</p>

    <br>

    <button type="button"
            onclick="submitForm()">
        Submit
    </button>

    <output id="confirmation"></output>
</form>
```

</section>

<section>
    <h2>Video Invite</h2>

```
<video width="400" controls oncanplay="videoReady()">
    <source src="" type="video/mp4">
</video>

<p id="videoMsg"></p>
```

</section>

<section>
    <h2>Find Nearby Events</h2>

```
<button onclick="findLocation()">
    Find Nearby Events
</button>

<p id="location"></p>
```

</section>

<section>
    <button onclick="clearPreferences()">
        Clear Preferences
    </button>
</section>

<!-- Footer -->

<footer>
    <p>© 2026 Local Community Event Portal</p>
</footer>

</body>
</html>

